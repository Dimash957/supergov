# eGov Integration Configuration
# Скопируйте в backend/.env и заполните значениями.
# Если EGOV_API_KEY нет, используйте demo mode (ниже).

# === eGov API Credentials ===
# Получите у eGov казахстана
EGOV_API_BASE_URL=https://api.egov.kz/v1
EGOV_API_KEY=your_api_key_here_replace_me
EGOV_COMPANY_ID=your_company_id_here

# === Demo mode (без EGOV_API_KEY) ===
# Для локальной разработки и демо окружения:
EGOV_MOCK=true
DEMO_MODE=true

# === Optional but Recommended ===
# Для логирования запросов
DEBUG_EGOV_API=true

# Для кэширования (в секундах)
EGOV_CACHE_TTL=3600

# Для timeout запросов (в секундах)
EGOV_REQUEST_TIMEOUT=30
